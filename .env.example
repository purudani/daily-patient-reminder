# Daily Patient Reminder – copy to .env and fill in. Do not commit .env.

# --- Microsoft Graph ---
#
# App-only (no sign-in): set CLIENT_ID, CLIENT_SECRET, TENANT_ID, MAILBOX_USER.
# Azure: Application permission Mail.Send (+ admin consent).
#
# Delegated (sign-in): set CLIENT_ID only; leave CLIENT_SECRET empty.
#
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
GRAPH_MAILBOX_USER=deepak@libertyptnj.com

# Event timezone for ICS + web calendar links (IANA recommended)
# TIMEZONE=America/New_York
# Outlook.com personal accounts: use live host for the “Add to Outlook” button
# OUTLOOK_CALENDAR_WEB_BASE=https://outlook.live.com

# Optional: override paths (defaults use project folder)
# REMINDER_BASE_FOLDER=
# ACTION_REPORT_PATH=
# ACTUAL_REPORT_PATH=
# MAILCHIMP_EXPORT_PATH=
# EVENT_ID_STORE_PATH=
# One row per email sent (audit). Leave unset for default invite_sent_log.xlsx in project folder.
# INVITE_LOG_PATH=
# REMINDER_LOG_FOLDER=
# Optional test override for skip logic "today" date:
# REFERENCE_DATE=2026-03-13

# Optional: sheet names or indices if different from config.py defaults
# ACTION_SHEET_NAME=Action
# ACTUAL_SHEET_NAME=Actual
# Example production tab names:
# ACTION_SHEET_NAME=3-16 action appt
# ACTUAL_SHEET_NAME=3-16 actual appt
# If reschedule text is under "Reschedule Info" instead of "Reschedule Into":
# COL_RESCHEDULE_INTO_ALIASES=Reschedule Info
# MAILCHIMP_SHEET_NAME=Sheet1

# If Actual sheet uses different column headers than Action (e.g. Mailchimp-style export):
# ACTUAL_COL_DATE=Last Schedul
# ACTUAL_COL_TIME=Time

# --- HTML appointment email (calendar invite body) ---
# Optional logo image URL for the email header (HTTPS recommended)
# EMAIL_LOGO_URL=https://libertyptnj.com/path/to/logo.png
# Inbox preview / preheader text
# EMAIL_PREVIEW_TEXT=Your appointment at Liberty PT & Wellness is confirmed.

